# 🚀 Java / Spring Boot / Maven .gitignore

# 🔹 Compiled class files

*.class

# 🔹 Logs

*.log

# 🔹 Maven target directory

target/

# 🔹 Maven Wrapper logs

.mvn/wrapper/maven-wrapper.jar

# 🔹 IDE files

# VS Code

.vscode/

# IntelliJ

.idea/
*.iml

# Eclipse

.project
.classpath
.settings/

# 🔹 OS files

.DS_Store
Thumbs.db

# 🔹 Environment files

.env

# 🔹 Build files

*.jar
*.war
*.ear

# 🔹 Temporary files

*.tmp
*.bak
*.swp

# 🔹 Node (if frontend added later)

node_modules/

# 🔹 Logs
logs/

# op imgs
op.docx


# 🔹 Test output

test-output/

# 🔹 Coverage reports

coverage/

# 🔹 Mac system files

.AppleDouble
.LSOverride

# 🔹 Windows system files

ehthumbs.db
Desktop.ini
